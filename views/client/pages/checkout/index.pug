
include ../../mixins/box-head.pug
include ../../mixins/alert.pug
block main
    +alert-success (5000)
    +alert-error(5000)
    .container.my-3
        .row
            .col-12
                +box-head("Đặt hàng")
        
        .row
            .col-12
                table(class="table table-bordered")
                    thead
                        tr
                            th STT
                            thi Ảnh
                            th Tên
                            th Giá
                            thì số lượng
                            th Tổng tiên
                    tbody
                        if(cartDetail.products.length > 0)
                            each item, index in cartDetail.products
                                td #{index+1}
                                td
                                    img(
                                    src=item.productInfo.thumbnail
                                    alt=item.productInfo.title
                                    width="80px")
                                td #{item.productInfo.title}
                                td #{item.productInfo.priceNow}$
                                td #{item.quantity}
                                td #{item.totalPrice}$
                        else
                            tr
                                td(
                                colspan="7"
                                class="text-center"
                                ) Giỏ hàng trong.
                if(cartDetail.products.length > 0)
                    h3(class="text-right") Tổng đơn hàng:
                    (cartDetail.totalPrice)$