extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
    +alert-success (5000)
    +alert-error(5000)

    .container.my-3
        .row
            .col-12
                +box-head("Giỏ hàng")
        .row
            .col-12
                table(class="table table-bordered")
                    thead
                        tr
                            th STT
                            th Ảnh
                            th Tên
                            th Giá
                            th Số lượng
                            th Tổng tiền
                            th Hành động
                    
                    tbody
                        if(listProductOfCart.length > 0)
                            each item, index in listProductOfCart
                                tr
                                    td #{index+1}
                                    td
                                        img(src=item.thumbnail, alt="Sản phẩm 1" width="80px")
                                    td
                                        a(href=`/products/detail/${item.slug}`) #{item.title}
                                    td #{item.price}$
                                    td
                                        input(
                                            type="number"
                                            name="quantity"
                                            value=item.quantity
                                            min="1"
                                            product-id=item.id
                                            style="width: 60px"
                                        )
                                    td #{item.totalPrice}
                                    td
                                        a(
                                            href=`/cart/delete/${item.id}`
                                            class="btn btn-danger"
                                        ) Xóa
                            

                h3(class="text-right") Tổng đơn hàng: #{totalPriceCart}$
                div(class="text-right mt-3")
                    a(href="/checkout" class="btn btn-success") THANH TOÁN

    script(src="/js/cart.js") 