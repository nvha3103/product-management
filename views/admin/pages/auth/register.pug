extends ../../layouts/auth.pug

block main
    h2 Đăng ký tài khoản
    
    if error && error.length
        each err in error
            .alert.alert-danger= err
    
    if success && success.length
        each suc in success
            .alert.alert-success= suc
    
    form(action=`${prefixAdmin}/auth/register`, method="POST")
        .form-group
            label Họ và tên
            input.form-control(type="text", name="fullName", placeholder="Nhập họ tên", required)
        
        .form-group
            label Email
            input.form-control(type="email", name="email", placeholder="Nhập email", required)
        
        .form-group
            label Mật khẩu
            input.form-control(type="password", name="password", placeholder="Nhập mật khẩu", minlength="6", required)
        
        .form-group
            label Xác nhận mật khẩu
            input.form-control(type="password", name="confirmPassword", placeholder="Nhập lại mật khẩu", required)
        
        button.btn.btn-primary(type="submit") Đăng ký
    
    .auth-footer
        p Đã có tài khoản? 
            a(href=`${prefixAdmin}/auth/login`) Đăng nhập
