extends ../../layouts/default.pug
include ../../mixins/sort-category.pug
//- include ../../mixins/filterStatus.pug
include ../../mixins/search.pug
include ../../mixins/table-tree.pug
block main

        //- if(role.permissions.includes("products-category_view"))
        h1 Danh sách bài viết

        //- div #{records}

        //- .card.mb-3
        //-     .card-header Bộ lọc và Tìm kiếm
        //-     .card-body
        //-     .row
        //-         .col-6 
        //-             +search(keyword)

        .card.mb-3
            .card-body
                .row
                    .col-4
                        //- if(role.permissions.includes("products-category_create"))
                        a(
                            href=`${prefixAdmin}/articles/create`
                            class="btn btn-outline-success"
                        ) + Them moi      


        //- .card.mb-3
        //-     .card-header Sắp xếp
        //-     .card-body
        //-         .row
        //-             .col-4
        //-                 +sortCategory()
        
        .card.mb-3
            .card-header Danh sach 
            .card-body
                
                table(
                    class="table table-hover table-sm"
                    checkbox-multi
                )
                    thead
                        tr
                            th
                                input(type="checkbox" name="checkall")
                            th STT
                            th Hình ảnh
                            th Tiêu đề
                            th Vị trí
                            th Trạng thái
                            th Hành động

                    tbody 
                        each item, index in articles
                            tr
                                td
                                    input(
                                        type="checkbox"
                                        name="id"
                                        value=item.id
                                    )
                                td #{index + 1}
                                td
                                    img(
                                        src=item.thumbnail
                                        alt=item.title
                                        style="width: 80px; height: 80px"
                                    )
                                td #{item.title}
                                td #{item.position} 
                                td #{item.status} 
                                td 
                                    a(
                                        href= `${prefixAdmin}/articles/detail/${item.id}`
                                        class="btn btn-secondary btn-sm"
                                        ) Chi tiết
                                    //- if(role.permissions.includes("products_edit"))
                                    a(
                                        href=`${prefixAdmin}/articles/edit/${item.id}` 
                                        class="btn btn-warning btn-sm") Sua
                                    //- if(role.permissions.includes("products_delete"))
                                    button(
                                        class="btn btn-danger btn-sm ml-1"
                                        button-delete
                                        data-id=item.id
                                    ) Xoa
