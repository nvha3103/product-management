extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/select-tree.pug
block main
  +alert-error(5000)
  +alert-success(5000)

  .edit-product-container
    .form-card
      h1(class="mb-45") Chỉnh sửa sản phẩm

      form(
        action=`${prefixAdmin}/products-category/edit/${product.id}?_method=PATCH`
        id="form-edit-product"
        method="POST"
        enctype="multipart/form-data" 
      )
        div(class="form-group")
          label(for="title") Tiêu đề
          input(
            type="text"
            class="form-control"
            id="title"
            name="title"
            value=product.title
            required
          )
        
        div(class="form-group")
            label(for="parent_id") Danh mục
            select(
                class="form-control"
                id="parent_id"
                name="parent_id"
            )
                option(value="") Chọn danh mục--
                if(category)
                  +select-tree(category)

        div(class="form-group")
          label(for="desc") Mô tả
          textarea(
            class="form-control textarea-mce"
            id="desc"
            name="description"
            rows="5"
          ) #{product.description}

        div(
          class="form-group"
          upload-image
        )
          label(for="thumbnail") Ảnh sản phẩm
          input(
            type="file"
            class="form-control-file mb-2"
            id="thumbnail"
            name="thumbnail"
            accept="image/*"
            upload-image-input
          )
          img(
            upload-image-preview
            src=(product.thumbnail ? product.thumbnail : "")
            alt="Preview"
            class="image-preview"
          )

        div(class="form-group")
          label(for="position") Vị trí
          input(
            type="number"
            class="form-control"
            id="position"
            name="position"
            min="1"
            value=product.position
          )

        div(class="mb-4")
          label(class="d-block") Trạng thái
          div(class="form-check form-check-inline")
            input(
              type="radio"
              class="form-check-input"
              id="statusActive"
              name="status"
              value="active"
              checked=(product.status == "active" ? true : false)
            )
            label(for="statusActive" class="form-check-label") Hoạt động
          
          div(class="form-check form-check-inline")
            input(
              type="radio"
              class="form-check-input"
              id="statusInactive"
              name="status"
              value="inactive"
              checked=(product.status == "inactive" ? true : false)
            )
            label(for="statusInactive" class="form-check-label") Dừng hoạt động

        div(class="form-group mb-0")
          button(type="submit" class="btn btn-primary") Cập nhật thông tin

  link(rel="stylesheet", href="/admin/css/editCategory.css")
  script(src="/admin/js/product.js")